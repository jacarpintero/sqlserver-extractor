# =============================================================================
# WINDOWS — Extractor SQL Server -> S3
# =============================================================================

# Servidor SQL Server (nombre, IP, o SERVIDOR\INSTANCIA)
SQL_SERVER=NOMBRE_SERVIDOR

# URL del API server en EC2 (para notificar trigger post-extraccion)
EC2_API_URL=http://<ip-ec2>:8000
EC2_API_TOKEN=un_token_secreto

# =============================================================================
# EC2 — ETL Loader + API Server
# =============================================================================

# PostgreSQL
DB_HOST=localhost
DB_NAME=nombre_db
DB_USER=usuario
DB_PASSWORD=password

# Token de autenticacion del API (debe coincidir con EC2_API_TOKEN en Windows)
EC2_API_TOKEN=un_token_secreto

# =============================================================================
# COMPARTIDO — AWS S3
# =============================================================================

AWS_ACCESS_KEY_ID=tu_access_key
AWS_SECRET_ACCESS_KEY=tu_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=nombre-de-tu-bucket
